# ==============================
# Server
# ==============================
PORT=5000
NODE_ENV=development

# ==============================
# MongoDB
# ==============================
MONGO_URI=mongodb://127.0.0.1:27017/campaign_monitoring

# ==============================
# Google Ads API
# Leave GOOGLE_ADS_MOCK_MODE=true to run without real credentials
# (generates realistic fake campaign data on every poll cycle).
# ==============================
GOOGLE_ADS_MOCK_MODE=true
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ==============================
# Telegram Bot
# ==============================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ==============================
# Scheduler
# ==============================
CAMPAIGN_FETCH_CRON=*/1 * * * *
RULE_EVALUATION_CRON=*/1 * * * *

# ==============================
# Alerting
# ==============================
DEFAULT_ALERT_COOLDOWN_MINUTES=15
DEFAULT_SPEND_LIMIT=50

# ==============================
# Dashboard Login
# ADMIN_* vars are used ONCE by `npm run seed:admin` to bootstrap the first
# admin account in the database (media buyer accounts are then created from
# the dashboard's Media Buyers page, not via env vars). Change JWT_SECRET
# before deploying anywhere reachable outside your own machine.
# ==============================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Admin
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
